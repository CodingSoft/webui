# ============================================
# CodingSoft WebUI - Configuración VPS
# ============================================
# Copiar este archivo a .env y configurar los valores

# ============================================
# CONFIGURACIÓN BÁSICA
# ============================================

# Clave secreta para WebUI (generar una aleatoria segura)
# Comando: openssl rand -hex 32
WEBUI_SECRET_KEY=tu-clave-secreta-aqui-cambia-esto

# Habilitar registro de usuarios (true/false)
ENABLE_SIGNUP=true

# Idioma por defecto
DEFAULT_LOCALE=es

# Modelos por defecto (separados por coma)
DEFAULT_MODELS=

# ============================================
# CONFIGURACIÓN DE TOOL SERVERS (IMPORTANTE)
# ============================================
# Estos servidores se cargan automáticamente al iniciar
# Los servidores deben estar accesibles desde el contenedor de WebUI

TOOL_SERVER_CONNECTIONS=[
  {
    "url": "http://filesystem-server:8000",
    "path": "/openapi.json",
    "type": "openapi",
    "auth_type": "none",
    "config": {
      "name": "Filesystem",
      "description": "Gestión segura de archivos"
    }
  },
  {
    "url": "http://memory-server:8000",
    "path": "/openapi.json",
    "type": "openapi",
    "auth_type": "none",
    "config": {
      "name": "Memory",
      "description": "Persistencia y knowledge graph"
    }
  },
  {
    "url": "http://time-server:8000",
    "path": "/openapi.json",
    "type": "openapi",
    "auth_type": "none",
    "config": {
      "name": "Time",
      "description": "Utilidades de tiempo y timezone"
    }
  },
  {
    "url": "http://git-server:8000",
    "path": "/openapi.json",
    "type": "openapi",
    "auth_type": "none",
    "config": {
      "name": "Git",
      "description": "Gestión de repositorios Git"
    }
  }
]

# ============================================
# CONFIGURACIÓN DE JWT (SEGURIDAD)
# ============================================

# Clave secreta JWT (generar una aleatoria segura)
# Comando: openssl rand -hex 32
JWT_SECRET_KEY=tu-jwt-secreto-aqui-cambia-esto

# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================

# SQLite (por defecto)
DATABASE_URL=sqlite:////app/backend/data/webui.db

# PostgreSQL (opcional, descomentar para usar)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/codingsoft

# ============================================
# CONFIGURACIÓN DE OLLAMA
# ============================================

# URL del servidor Ollama (dentro de la red Docker)
OLLAMA_BASE_URL=http://ollama:11434

# Habilitar API de Ollama
ENABLE_OLLAMA_API=true

# ============================================
# CONFIGURACIÓN DE CORS
# ============================================

# Orígenes permitidos (separados por coma)
# Para producción, usar tu dominio específico
# CORS_ALLOW_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com
CORS_ALLOW_ORIGINS=*

# ============================================
# API KEYS PARA SERVICIOS EXTERNOS
# ============================================

# Google PSE (Búsqueda web)
GOOGLE_API_KEY=
GOOGLE_PSE_CX=

# OpenAI (para SQL Chat y otros servicios)
OPENAI_API_KEY=

# Slack (integración)
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=
SLACK_CHANNEL_IDS=

# Base de datos externa (para SQL Chat)
EXTERNAL_DATABASE_URL=

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================

# API Key para servidores de archivos
FILESYSTEM_SERVER_API_KEY=

# Habilitar validación de contenido
ENABLE_WEB_SEARCH_SAFETY=true
CONTENT_VALIDATION_API_KEY=

# ============================================
# CONFIGURACIÓN DE CARACTERÍSTICAS
# ============================================

# RAG (Retrieval-Augmented Generation)
ENABLE_RAG=true

# Generación de imágenes
ENABLE_IMAGE_GENERATION=true

# Búsqueda web
ENABLE_WEB_SEARCH=true
WEB_SEARCH_ENGINE=duckduckgo

# Autocompletado
ENABLE_AUTOCOMPLETE_GENERATION=true

# Generación de tags
ENABLE_TAGS_GENERATION=true

# Generación de títulos
ENABLE_TITLE_GENERATION=true

# Herramientas
ENABLE_TOOLS=true

# Ejecución de código
ENABLE_CODE_EXECUTION=true

# Compartir con comunidad
ENABLE_COMMUNITY_SHARING=false

# Exportación de admin
ENABLE_ADMIN_EXPORT=true

# Acceso a chats de admin
ENABLE_ADMIN_CHAT_ACCESS=true

# Verificación de actualizaciones
ENABLE_VERSION_UPDATE_CHECK=true

# ============================================
# CONFIGURACIÓN DE OAUTH (OPCIONAL)
# ============================================

# OAuth Client ID
OAUTH_CLIENT_ID=

# OAuth Client Secret
OAUTH_CLIENT_SECRET=

# Nombre del proveedor OAuth
OAUTH_PROVIDER_NAME=

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Puerto del servidor WebUI
OPEN_WEBUI_PORT=8080

# Tag de imagen Docker
WEBUI_DOCKER_TAG=main

# Tag de imagen Ollama
OLLAMA_DOCKER_TAG=latest
